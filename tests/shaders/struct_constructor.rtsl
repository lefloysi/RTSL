struct Point {
    vec3 position;
    vec2 uv;
};

struct Vertex {
    vec4 position;
    vec2 uv;
    fn Vertex(Point p);
};

fn Vertex::Vertex(Point p) {
    position = vec4(p.position, 1.0);
    uv = p.uv;
}

@vertex
fn vertex_entry(Point p) -> Vertex : position(clip), uv(smooth) {
    return Vertex(p);
}
