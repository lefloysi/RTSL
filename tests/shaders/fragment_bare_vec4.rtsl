struct Point {
    vec3 position;
};

struct Vertex {
    vec4 position;
    fn Vertex(Point p);
};

fn Vertex::Vertex(Point p) {
    position = vec4(p.position, 1.0);
}

@vertex
fn vertex_entry(Point p) -> Vertex : position(clip) {
    return Vertex(p);
}

@fragment
fn fragment_entry(Vertex v) -> vec4 {
    return vec4(1.0, 0.0, 0.0, 1.0);
}
