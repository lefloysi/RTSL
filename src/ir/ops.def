// ops.def — the RTIR opcode set.
//
//   RTSL_IR_OP(name, disasm_name)
//
// `name` is the IROp enumerator; `disasm_name` is the SPIR-V-style mnemonic
// the disassembler prints. The operand/literal shape of each op is documented
// in docs/rtir.md.
//
// ORDER IS WIRE FORMAT: opcodes serialize into .rtslo/.rtslm/.rtslp files as
// their enum value (u16, starting at 0). Append new ops at the end; never
// reorder or remove.

#ifndef RTSL_IR_OP
#define RTSL_IR_OP(name, disasm_name)
#endif

RTSL_IR_OP(Nop, "OpNop")

// --- Types (results go into IRModule::type_constant_pool) ---
RTSL_IR_OP(TypeVoid, "OpTypeVoid")
RTSL_IR_OP(TypeBool, "OpTypeBool")
RTSL_IR_OP(TypeInt, "OpTypeInt")                 // literal: width (bits)
RTSL_IR_OP(TypeUInt, "OpTypeUInt")               // literal: width (bits)
RTSL_IR_OP(TypeFloat, "OpTypeFloat")             // literal: width (bits)
RTSL_IR_OP(TypeVector, "OpTypeVector")           // operand: scalar type id; literal: component count
RTSL_IR_OP(TypeMatrix, "OpTypeMatrix")           // operand: column-vector type id; literal: column count
RTSL_IR_OP(TypeStruct, "OpTypeStruct")           // operands: member type ids
RTSL_IR_OP(TypePointer, "OpTypePointer")         // operand: pointee type id; literal: StorageClass
RTSL_IR_OP(TypeArray, "OpTypeArray")             // operand: element type id; literal: length (0 = runtime)
RTSL_IR_OP(TypeFunction, "OpTypeFunction")       // operands: return type id, parameter type ids...
RTSL_IR_OP(TypeImage, "OpTypeImage")
RTSL_IR_OP(TypeSampler, "OpTypeSampler")
RTSL_IR_OP(TypeSampledImage, "OpTypeSampledImage") // operand: image type id

// --- Constants ---
RTSL_IR_OP(ConstantBool, "OpConstantTrueFalse")  // literal: 0 or 1
RTSL_IR_OP(ConstantInt, "OpConstant")            // literal: low/high bits
RTSL_IR_OP(ConstantUInt, "OpConstant")           // literal: low/high bits
RTSL_IR_OP(ConstantFloat, "OpConstant")          // literal: bit pattern (low/high for 64-bit)
RTSL_IR_OP(ConstantComposite, "OpConstantComposite") // operands: element ids

// --- Variables / memory ---
RTSL_IR_OP(Variable, "OpVariable")               // literal: StorageClass; operand[0]: optional initializer id
RTSL_IR_OP(Load, "OpLoad")                       // operand[0]: pointer id
RTSL_IR_OP(Store, "OpStore")                     // operand[0]: pointer id; operand[1]: value id
RTSL_IR_OP(AccessChain, "OpAccessChain")         // operand[0]: base pointer id; operand[1..]: index ids

// --- Composite ---
RTSL_IR_OP(CompositeConstruct, "OpCompositeConstruct") // operands: element ids
RTSL_IR_OP(CompositeExtract, "OpCompositeExtract")     // operand[0]: composite id; literals: indices
RTSL_IR_OP(CompositeInsert, "OpCompositeInsert")       // operand[0]: composite id; operand[1]: value id; literals: indices
RTSL_IR_OP(VectorShuffle, "OpVectorShuffle")           // operand[0..1]: vec ids; literals: component indices

// --- Arithmetic ---
RTSL_IR_OP(FAdd, "OpFAdd")
RTSL_IR_OP(FSub, "OpFSub")
RTSL_IR_OP(FMul, "OpFMul")
RTSL_IR_OP(FDiv, "OpFDiv")
RTSL_IR_OP(FMod, "OpFRem")
RTSL_IR_OP(FNegate, "OpFNegate")
RTSL_IR_OP(IAdd, "OpIAdd")
RTSL_IR_OP(ISub, "OpISub")
RTSL_IR_OP(IMul, "OpIMul")
RTSL_IR_OP(SDiv, "OpSDiv")
RTSL_IR_OP(UDiv, "OpUDiv")
RTSL_IR_OP(SMod, "OpSMod")
RTSL_IR_OP(UMod, "OpUMod")

// --- Vector / matrix ---
RTSL_IR_OP(VectorTimesScalar, "OpVectorTimesScalar")
RTSL_IR_OP(MatrixTimesScalar, "OpMatrixTimesScalar")
RTSL_IR_OP(MatrixTimesVector, "OpMatrixTimesVector")
RTSL_IR_OP(MatrixTimesMatrix, "OpMatrixTimesMatrix")
RTSL_IR_OP(Dot, "OpDot")
RTSL_IR_OP(Cross, "OpExtInstCross")

// --- Comparison / logical ---
RTSL_IR_OP(FOrdEqual, "OpFOrdEqual")
RTSL_IR_OP(FOrdNotEqual, "OpFOrdNotEqual")
RTSL_IR_OP(FOrdLess, "OpFOrdLessThan")
RTSL_IR_OP(FOrdLessEqual, "OpFOrdLessThanEqual")
RTSL_IR_OP(FOrdGreater, "OpFOrdGreaterThan")
RTSL_IR_OP(FOrdGreaterEqual, "OpFOrdGreaterThanEqual")
RTSL_IR_OP(IEqual, "OpIEqual")
RTSL_IR_OP(INotEqual, "OpINotEqual")
RTSL_IR_OP(SLess, "OpSLessThan")
RTSL_IR_OP(SLessEqual, "OpSLessThanEqual")
RTSL_IR_OP(SGreater, "OpSGreaterThan")
RTSL_IR_OP(SGreaterEqual, "OpSGreaterThanEqual")
RTSL_IR_OP(ULess, "OpULessThan")
RTSL_IR_OP(ULessEqual, "OpULessThanEqual")
RTSL_IR_OP(UGreater, "OpUGreaterThan")
RTSL_IR_OP(UGreaterEqual, "OpUGreaterThanEqual")
RTSL_IR_OP(LogicalAnd, "OpLogicalAnd")
RTSL_IR_OP(LogicalOr, "OpLogicalOr")
RTSL_IR_OP(LogicalNot, "OpLogicalNot")

// --- Conversion ---
RTSL_IR_OP(ConvertFToU, "OpConvertFToU")
RTSL_IR_OP(ConvertFToS, "OpConvertFToS")
RTSL_IR_OP(ConvertSToF, "OpConvertSToF")
RTSL_IR_OP(ConvertUToF, "OpConvertUToF")
RTSL_IR_OP(Bitcast, "OpBitcast")

// --- Control flow ---
RTSL_IR_OP(Label, "OpLabel")                     // begins a basic block; no operands
RTSL_IR_OP(Branch, "OpBranch")                   // operand[0]: target label id
RTSL_IR_OP(BranchConditional, "OpBranchConditional") // operand[0]: cond; operand[1]: true label; operand[2]: false label
RTSL_IR_OP(SelectionMerge, "OpSelectionMerge")   // operand[0]: merge label; literal: SelectionControl
RTSL_IR_OP(LoopMerge, "OpLoopMerge")             // operand[0]: merge label; operand[1]: continue label; literal: LoopControl
RTSL_IR_OP(Return, "OpReturn")
RTSL_IR_OP(ReturnValue, "OpReturnValue")         // operand[0]: value id

// --- Function ---
RTSL_IR_OP(FunctionParameter, "OpFunctionParameter") // result: parameter id; type_id: parameter type
RTSL_IR_OP(FunctionCall, "OpFunctionCall")           // operand[0]: callee function id; operand[1..]: arg ids

// --- Image / sampler ---
RTSL_IR_OP(SampledImage, "OpSampledImage")                       // operand[0]: image id; operand[1]: sampler id
RTSL_IR_OP(ImageSampleImplicitLod, "OpImageSampleImplicitLod")   // operand[0]: sampled image id; operand[1]: coords id
RTSL_IR_OP(ImageSampleExplicitLod, "OpImageSampleExplicitLod")   // operand[0]: sampled image; operand[1]: coords; operand[2]: lod
RTSL_IR_OP(ImageRead, "OpImageRead")
RTSL_IR_OP(ImageWrite, "OpImageWrite")

// --- Stage I/O primitives ---
// High-level RTSL primitives. The SPIR-V backend lowers these to Load/Store
// against Input/Output storage class variables. Keeping them as first-class
// ops means stage interface assignment can stay metadata-driven instead of
// requiring the IR to spell out every reflected stage variable up front.
RTSL_IR_OP(ReadInput, "OpRTReadInput")           // literal: location
RTSL_IR_OP(WriteOutput, "OpRTWriteOutput")       // operand[0]: value id; literal: location
RTSL_IR_OP(ReadBuiltin, "OpRTReadBuiltin")       // literal: BuiltIn enum
RTSL_IR_OP(WriteBuiltin, "OpRTWriteBuiltin")     // operand[0]: value id; literal: BuiltIn enum

// --- Standard library / extended set ---
RTSL_IR_OP(ExtInst, "OpExtInst") // literal[0]: ext set id (0 = rt.std.450); literal[1]: ext op number; operands: arg ids

#undef RTSL_IR_OP
